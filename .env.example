# Orchestrator — пример переменных окружения
# Скопируй в .env и заполни

# Telegram (отдельный бот, НЕ тот что у ShortsProject)
ORC_TG_TOKEN=your_bot_token_here
ORC_TG_CHAT_ID=your_chat_id_here

# LLM модели (Ollama)
ORC_STRATEGY_MODEL=llama3.1
ORC_CODE_MODEL=qwen2.5-coder:7b
ORC_LLM_TIMEOUT=120

# Цикл
ORC_CYCLE_HOURS=1

# Время суточной сводки (локальное время)
ORC_DIGEST_TIME=09:00

# ВАЖНО: сначала запусти с DRY_RUN=true чтобы убедиться что всё корректно
ORC_DRY_RUN=true
