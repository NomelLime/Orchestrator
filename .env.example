# Orchestrator — пример переменных окружения
# Скопируй в .env и заполни

# ── Telegram ─────────────────────────────────────────────────────────────────
# Orchestrator — единственный бот, принимающий команды. Один чат со всеми тремя проектами.
ORC_TG_TOKEN=your_bot_token_here
ORC_TG_CHAT_ID=your_chat_id_here

# ── LLM модели (Ollama) ───────────────────────────────────────────────────────
ORC_STRATEGY_MODEL=llama3.1
ORC_CODE_MODEL=qwen2.5-coder:7b
ORC_LLM_TIMEOUT=120

# ── Цикл и расписание ─────────────────────────────────────────────────────────
ORC_CYCLE_HOURS=1
# Время суточной сводки (локальное время). Заменяет дайджест PreLend.
ORC_DIGEST_TIME=09:00

# ── Режим запуска ─────────────────────────────────────────────────────────────
# ВАЖНО: при первом запуске держи DRY_RUN=true — планы генерируются, но не применяются
ORC_DRY_RUN=true

# ── Прокси (mobileproxy.space) ────────────────────────────────────────────────
# API-ключ с сайта mobileproxy.space → Личный кабинет → API
ORC_MOBILEPROXY_API_KEY=your_mobileproxy_api_key_here

# Минимальный баланс (руб.) — при падении ниже придёт Telegram-уведомление
ORC_PROXY_MIN_BALANCE=300

# За сколько дней до истечения прокси присылать запрос на продление
ORC_PROXY_EXPIRY_DAYS=3

# Сколько банов за 24ч = спайк (рекомендация докупить прокси)
ORC_PROXY_BAN_THRESH=5

# Проверять прокси раз в N циклов (по умолчанию каждые 6 часов при ORC_CYCLE_HOURS=1)
ORC_SUPPLY_CHECK_CYCLES=6

# ── Краш-луп детектор ─────────────────────────────────────────────────────────
# Окно анализа краш-лупа в минутах
ORC_CRASH_WINDOW_MIN=60

# Минимум restart_requested за окно для автооткатa патча
ORC_CRASH_MIN_RESTARTS=3
